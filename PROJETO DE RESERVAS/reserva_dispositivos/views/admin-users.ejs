<!DOCTYPE html>
<html lang="pt-br" data-theme="white">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Admin - Gerir Utilizadores</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"/>
        <link rel="stylesheet" href="/style.css">
        <style>
            .toolbar {
                display: flex;
                gap: 1rem;
                align-items: end;
                margin-bottom: 1rem;
                flex-wrap: wrap;
            }
            .toolbar label {
                margin-bottom: 0;
                min-width: 260px;
                flex: 1;
            }
            .action-stack {
                display: flex;
                gap: 10px;
                align-items: center;
                justify-content: flex-start;
                flex-wrap: nowrap;
                min-width: 600px;
            }
            .role-form {
                display: flex;
                gap: 0.5rem;
                align-items: center;
                margin: 0;
                flex: 1;
            }
            .action-stack form {
                margin: 0;
            }
            .role-form select,
            .role-form button,
            .delete-button {
                margin: 0;
                height: 44px;
            }
            .role-form select {
                margin: 0;
            height: 45px;
            min-width: 180px; /* Largura mínima para o texto do perfil aparecer */
            padding-top: 0;
            padding-bottom: 0;
            }
            .role-form button,
            .delete-button {
                min-width: 160px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                text-align: center;
                white-space: nowrap;
            }
            .self-role-note {
                display: inline-flex;
                align-items: center;
                justify-content: flex-start;
                min-height: 44px;
                white-space: nowrap;
            }
            .muted-note {
                color: #666;
                font-size: 0.92rem;
                margin: 0 0 1rem;
            }
            .users-table th.col-acoes,
            .users-table td.col-acoes {
                min-width: 640px;
            }
        </style>
    </head>
<body>
    <main class="container-fluid">
        <header class="logo-header">
            <img src="/images/logo_azul.png" alt="Logo do Colégio">
            <h1>Painel do Administrador</h1>
            <div style="margin-left: auto; text-align: right;">
                <p style="margin: 0;"><%= user.nome.split(' ')[0] %></p>
                <a href="/logout" role="button" class="secondary outline" style="padding: 5px 10px; margin-top: 5px;">Sair</a>
            </div>
        </header>

        <!-- NAVEGAÇÃO CENTRALIZADA (PILLS) -->
        <nav class="nav-pills-container">
            <a href="/" class="nav-pill">Fazer Nova Reserva</a>
            <a href="/admin" class="nav-pill active">Gerenciar Reservas</a>
            <% if (user.role === 'admin') { %>
                <a href="/admin/users" class="nav-pill">Gerir Utilizadores</a>
            <% } %>
            <a href="/admin/history" class="nav-pill">Histórico de Reservas</a>
            <a href="/admin/dashboard">Dashboard de Reservas</a>
        </nav>

        <h2>Usúarios que efetuaram login no sistema</h2>
        <p class="muted-note">Use o filtro para localizar rapidamente um usuário e altere o perfil pelo seletor.</p>

        <div class="toolbar">
            <label for="filtro-usuarios">
                Procurar usuário
                <input type="search" id="filtro-usuarios" placeholder="Digite nome, e-mail ou perfil">
            </label>
        </div>
        
        <div style="overflow-x: auto;">
            <table class="users-table">
              <thead>
                <tr>
                  <th class="col-nome">Nome</th>
                  <th class="col-email">E-mail</th>
                  <th class="col-papel">Função</th>
                  <th class="col-acoes">Alterar Permissão</th>
                </tr>
              </thead>
              <tbody>
                <% usuarios.forEach(usuario => { %>
                  <tr data-user-row data-search="<%= `${usuario.nome} ${usuario.email} ${usuario.role}`.toLowerCase() %>">
                    <td><%= usuario.nome %></td>
                    <td><%= usuario.email %></td>
                    <td><%= usuario.role.charAt(0).toUpperCase() + usuario.role.slice(1) %></td>
                    <td class="col-acoes">
                      <div class="action-stack">
                        <% if (usuario.id !== user.id) { %>
                          <form action="/admin/set-role/<%= usuario.id %>" method="POST" class="role-form">
                            <select name="role" aria-label="Selecionar perfil para <%= usuario.nome %>">
                              <option value="professor" <%= usuario.role === 'professor' ? 'selected' : '' %>>Professor</option>
                              <option value="operacional" <%= usuario.role === 'operacional' ? 'selected' : '' %>>Operacional</option>
                              <option value="admin" <%= usuario.role === 'admin' ? 'selected' : '' %>>Admin</option>
                            </select>
                            <button type="submit" class="outline">Salvar perfil</button>
                          </form>

                          <form action="/admin/delete/<%= usuario.id %>" method="POST" onsubmit="return confirm('Tem a certeza de que deseja excluir este utilizador?');">
                              <button type="submit" class="contrast delete-button">Excluir</button>
                          </form>

                        <% } else { %>
                          <p class="self-role-note">(Administrador)</p>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
        </div>
    </main>
    <script>
        const filtroUsuarios = document.getElementById('filtro-usuarios');
        const linhasUsuarios = Array.from(document.querySelectorAll('[data-user-row]'));

        filtroUsuarios.addEventListener('input', function() {
            const termo = this.value.trim().toLowerCase();

            linhasUsuarios.forEach((linha) => {
                const textoBusca = linha.getAttribute('data-search') || '';
                linha.style.display = !termo || textoBusca.includes(termo) ? '' : 'none';
            });
        });
    </script>
  </body>
</html>
