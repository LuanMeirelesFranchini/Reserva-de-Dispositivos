<!DOCTYPE html>
<html lang="pt-br" data-theme="white">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Reserva - La Salle</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"/>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
</head>
<body>
    <main class="container-fluid">
        <header class="logo-header">
            <img src="/images/logo_azul.png" alt="Logo do Colégio">
            <h1>Sistema de Reservas</h1>
            
            <div class="user-menu-container">
                <button type="button" class="user-menu-button" aria-haspopup="true" aria-expanded="false">
                    <span>Olá, <strong><%= user.nome.split(' ')[0] %></strong></span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                </button>
                <div class="dropdown-content">
                    <a href="/minhas-reservas">Minhas Reservas</a>
                    <% if (user.role === 'admin' || user.role === 'operacional') { %>
                        <a href="/admin">Painel de Gestão</a>
                        <a href="/admin/dashboard">Dashboard de Reservas</a>
                    <% } %>
                    <% if (user.role === 'admin') { %>
                        <a href="/admin/inventario">Gestão de Inventário</a>
                    <% } %>
                    <hr style="margin: 0; opacity: 0.1;">
                    <a href="/logout" style="color: #d32f2f;">Sair da Conta</a>
                </div>
            </div>
        </header>
    
        <% if (typeof erro !== 'undefined' && erro) { %>
        <article style="background-color: #ffebee; border-color: #e57373;">
            <p style="color: #c62828;"><%= erro %></p>
        </article>
        <% } %>
        
        <% if (typeof sucesso !== 'undefined' && sucesso) { %>
        <article style="background-color: #e8f5e9; border-color: #81c784;">
            <p style="color: #2e7d32;"><%= sucesso %></p>
        </article>
        <% } %>
        
        <h2>Disponibilidade por Carrinho</h2>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Carrinho</th>
                        <th>Localização</th>
                        <th style="text-align: center;">Capacidade Total</th>
                    </tr>
                </thead>
                <tbody>
                    <% carrinhos.forEach(c => { %>
                    <tr>
                        <td><%= c.nome %></td>
                        <td><%= c.localizacao %></td>
                        <!-- MUDANÇA: Usando 'quantidade_total' vindo da sua DB -->
                        <td style="text-align: center;"><strong><%= c.quantidade_total || c.capacidade %></strong></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <hr>

        <details open>
            <summary role="button" class="outline">Fazer uma Nova Reserva</summary>
            <form id="formReserva" action="/reservar" method="POST">
                <label for="carrinho">De qual carrinho quer reservar?</label>
                <select id="carrinho" name="carrinho_id" required>
                    <option value="" disabled selected>Escolha um carrinho</option>
                    <% carrinhos.forEach(c => { %>
                        <!-- MUDANÇA: Guardamos a capacidade no 'data-max' para o JS ler depois -->
                        <option value="<%= c.id %>" data-max="<%= c.quantidade_total || c.capacidade %>">
                            <%= c.nome %> - <%= c.localizacao %>
                        </option>
                    <% }) %>
                </select>

                <label for="quantidade">Quantidade:</label>
                <input type="number" id="quantidade" name="quantidade" required min="1" placeholder="Selecione um carrinho primeiro">

                <div class="grid">
                    <label for="retirada">Data e Hora de Retirada:
                        <input type="text" id="retirada" name="data_retirada" required placeholder="Selecione data e hora...">
                    </label>
                    <label for="devolucao">Data e Hora de Devolução:
                        <input type="text" id="devolucao" name="data_devolucao" required placeholder="Selecione data e hora...">
                    </label>
                </div>

                <label for="sala">Para qual sala?</label>
                <input type="text" id="sala" name="sala" required placeholder="Ex: Sala 15 - 231M">
                
                <p><b>Disponibilidade para este horário: <span id="disponibilidade-resultado">--</span></b></p>
        
                <button type="submit" id="btnReservar">Reservar</button>
            </form>
        </details>
    </main>
    
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://npmcdn.com/flatpickr/dist/l10n/pt.js"></script>
    <script src="/menu.js"></script>
    <script src="/front-end.js"></script>
    
    <script>
        const selectCarrinho = document.getElementById('carrinho');
        const inputQuantidade = document.getElementById('quantidade');

        // MUDANÇA: Lógica de limite dinâmico
        selectCarrinho.addEventListener('change', function() {
            const option = this.options[this.selectedIndex];
            const maxDisponivel = option.getAttribute('data-max');
            
            inputQuantidade.max = maxDisponivel;
            inputQuantidade.placeholder = `Máximo: ${maxDisponivel} unidades`;
            
            // Se o usuário já digitou algo maior que o novo máximo, ajusta
            if (parseInt(inputQuantidade.value) > parseInt(maxDisponivel)) {
                inputQuantidade.value = maxDisponivel;
            }
        });

        // Validação extra durante a digitação
        inputQuantidade.addEventListener("input", function(){
            const max = parseInt(this.max);
            if (max && parseInt(this.value) > max) {
                this.value = max;
            }
        });

        // Lógica de Loading no Botão
        const form = document.getElementById('formReserva');
        const btn = document.getElementById('btnReservar');

        if (form && btn) {
            form.addEventListener('submit', function() {
                btn.setAttribute('aria-busy', 'true');
                btn.disabled = true;
                btn.textContent = 'Processando sua reserva...';
            });
        }
    </script>
</body>
</html>
