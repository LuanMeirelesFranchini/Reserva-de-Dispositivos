<!DOCTYPE html>
<html lang="pt-br" data-theme="white">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Historico de Reservas</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"/>
    <link rel="stylesheet" href="/style.css">
    <style>
        .col-carrinho { white-space: nowrap; min-width: 130px; }
    </style>
</head>
<body>
    <main class="container-fluid">
        <%- include('partials/app-header', { title: 'Painel de Gestao', user }) %>
        <%- include('partials/admin-nav', { user, activePage: 'history' }) %>

        <h2 style="margin-top: 1rem; margin-bottom: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--pico-muted-border-color);">Histórico de Reservas</h2>

        <div style="background: var(--pico-card-background-color); padding: 1rem 1.5rem; border-radius: var(--pico-border-radius); border: 1px solid var(--pico-muted-border-color); margin: 0 auto 1.5rem auto; box-shadow: var(--pico-box-shadow); max-width: fit-content;">
            <form action="/admin/history" method="GET" style="margin-bottom: 0;">
                <div style="display: flex; align-items: flex-end; gap: 1rem; flex-wrap: wrap; justify-content: center;">
                    <div style="margin-bottom: 0;">
                        <label for="limit" style="font-size: 0.85rem; margin-bottom: 0.25rem;">Exibir:</label>
                        <select name="limit" id="limit" style="margin-bottom: 0; min-width: 80px;" onchange="this.form.submit()">
                            <option value="10" <%= currentLimit == 10 ? 'selected' : '' %>>10</option>
                            <option value="20" <%= currentLimit == 20 ? 'selected' : '' %>>20</option>
                            <option value="50" <%= currentLimit == 50 ? 'selected' : '' %>>50</option>
                            <option value="100" <%= currentLimit == 100 ? 'selected' : '' %>>100</option>
                        </select>
                    </div>
                    <div style="margin-bottom: 0;">
                        <label for="ordem" style="font-size: 0.85rem; margin-bottom: 0.25rem;">Ordem:</label>
                        <select name="ordem" id="ordem" style="margin-bottom: 0; min-width: 180px;" onchange="this.form.submit()">
                            <option value="recentes" <%= typeof ordemFiltro !== 'undefined' && ordemFiltro === 'recentes' ? 'selected' : '' %>>Mais recentes primeiro</option>
                            <option value="antigas" <%= typeof ordemFiltro !== 'undefined' && ordemFiltro === 'antigas' ? 'selected' : '' %>>Mais antigas primeiro</option>
                        </select>
                    </div>
                    <div style="margin-bottom: 0;">
                        <label for="data" style="font-size: 0.85rem; margin-bottom: 0.25rem;">Data da Retirada:</label>
                        <input type="date" id="data" name="data" value="<%= typeof dataFiltro !== 'undefined' ? dataFiltro : '' %>" style="margin-bottom: 0;">
                    </div>
                    <div style="margin-bottom: 0;">
                        <button type="submit" style="margin-bottom: 0;">Buscar</button>
                    </div>
                    <% if (typeof dataFiltro !== 'undefined' && dataFiltro) { %>
                        <div style="margin-bottom: 0;">
                            <a href="/admin/history" role="button" class="secondary outline" style="margin-bottom: 0; display: block; text-align: center;">Limpar</a>
                        </div>
                    <% } %>
                </div>
            </form>
        </div>
        
       <div class="table-container">
            <table class="striped">
                <thead>
                    <tr>
                        <th>Professor</th>
                        <th>Qtde</th>
                        <th>Carrinho</th>
                        <th>Feita em</th>
                        <th>Retirada</th>
                        <th>Devolucao</th>
                        <th>Sala</th>
                        <th style="text-align: center;">Concluida por</th>
                    </tr>
                </thead>
                <tbody>
                    <%
                    function formatarDataSimples(dataIso){
                        if(!dataIso) return '---';
                        const data = new Date(dataIso);
                        if (isNaN(data.getTime())) return 'Data Invalida';
                        
                        const dia = String(data.getDate()).padStart(2, '0');
                        const mes = String(data.getMonth()+1).padStart(2, '0');
                        const hora = String(data.getHours()).padStart(2, '0');
                        const minuto = String(data.getMinutes()).padStart(2, '0');
                        return `${hora}:${minuto} | ${dia}/${mes}`;
                    }
                    %>
                
                    <% if (reservas.length > 0) { %>
                        <% reservas.forEach(reserva => { %>
                            <tr>
                                <td><strong><%= reserva.nome_professor %></strong></td>
                                <td><%= reserva.quantidade %></td>
                                <td class="col-carrinho"><%= reserva.nome_carrinho %></td>
                                <td style="white-space: nowrap;"><%= formatarDataSimples(reserva.data_reserva) %></td>
                                <td style="white-space: nowrap;"><%= formatarDataSimples(reserva.data_retirada) %></td>
                                <td style="white-space: nowrap;"><%= formatarDataSimples(reserva.data_devolucao) %></td>
                                <td><%= reserva.sala %></td>
                                <td style="text-align: center;">
                                    <mark style="background: #e8f5e9; color: #2e7d32; font-size: 0.75rem; text-transform: uppercase; font-weight: bold;">
                                        <%= reserva.concluido_por || 'Concluida' %>
                                    </mark>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="8" style="text-align: center; padding: 2rem;">Nenhum registro encontrado no historico.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
            <nav style="margin-top: 2rem; margin-bottom: 4rem; display: flex; justify-content: center;">
                <div style="display: inline-flex; align-items: center; gap: 1rem; background: var(--pico-card-background-color); padding: 0.5rem 1rem; border-radius: 2rem; box-shadow: var(--pico-box-shadow); border: 1px solid var(--pico-muted-border-color);">
                    <% if (currentPage > 1) { %>
                        <a href="/admin/history?page=<%= currentPage - 1 %><%= (typeof dataFiltro !== 'undefined' && dataFiltro) ? '&data=' + dataFiltro : '' %>&limit=<%= currentLimit %><%= (typeof ordemFiltro !== 'undefined') ? '&ordem=' + ordemFiltro : '' %>" style="text-decoration: none; font-size: 0.9rem;">&laquo; Anterior</a>
                    <% } else { %>
                        <span style="opacity: 0.5; font-size: 0.9rem;">&laquo; Anterior</span>
                    <% } %>
                    
                    <span style="font-weight: 600; font-size: 0.9rem; color: var(--pico-color);">
                        Página <%= currentPage %> de <%= totalPages %>
                    </span>
                    
                    <% if (currentPage < totalPages) { %>
                        <a href="/admin/history?page=<%= currentPage + 1 %><%= (typeof dataFiltro !== 'undefined' && dataFiltro) ? '&data=' + dataFiltro : '' %>&limit=<%= currentLimit %><%= (typeof ordemFiltro !== 'undefined') ? '&ordem=' + ordemFiltro : '' %>" style="text-decoration: none; font-size: 0.9rem;">Próxima &raquo;</a>
                    <% } else { %>
                        <span style="opacity: 0.5; font-size: 0.9rem;">Próxima &raquo;</span>
                    <% } %>
                </div>
            </nav>
        <% } %>
    </main>
    <%- include('partials/footer') %>
</body>
</html>
