<!DOCTYPE html>
<html lang="pt-br" data-theme="white">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard de Reservas - La Salle</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"/>
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .section-stack {
            display: grid;
            gap: 1.5rem;
        }

        .period-banner {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
            padding: 1rem 1.2rem;
            border: 1px solid var(--pico-primary-border);
            border-radius: var(--pico-border-radius);
            background: var(--pico-primary-background);
            color: var(--pico-primary-inverse);
            box-shadow: var(--pico-box-shadow);
        }

        .period-banner h2,
        .period-banner p {
            margin: 0;
            color: var(--pico-primary-inverse);
        }

        .period-banner nav {
            display: flex;
            gap: 0.65rem;
            flex-wrap: wrap;
        }

        .period-banner nav a,
        .period-banner nav span {
            color: #ffffff;
            border-color: rgba(255, 255, 255, 0.34);
            margin: 0;
        }

        .period-chip {
            display: inline-flex;
            align-items: center;
            padding: 0.55rem 0.85rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.2);
            font-weight: 700;
        }

        .stats-grid,
        .alerts-grid,
        .panel-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1rem;
        }

        .panel-grid {
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        }

        .stat-card,
        .alert-card {
            padding: 1.1rem 1.2rem;
            border: 1px solid var(--pico-muted-border-color);
            border-radius: var(--pico-border-radius);
            background: var(--pico-card-background-color);
            box-shadow: var(--pico-box-shadow);
        }

        .stat-card small,
        .alert-card small {
            color: var(--pico-muted-color);
            display: block;
        }

        .stat-card strong {
            display: block;
            font-size: 2rem;
            color: var(--pico-color);
            margin-top: 0.35rem;
            line-height: 1.1;
        }

        .stat-card span {
            display: block;
            margin-top: 0.35rem;
            color: var(--pico-muted-color);
        }

        .alert-card {
            margin: 0;
        }

        .alert-card header {
            margin-bottom: 0.75rem;
        }

        .alert-card h3,
        .alert-card p {
            margin: 0;
        }

        .alert-card h3 {
            font-size: 1.1rem;
            line-height: 1.25;
            color: var(--pico-color);
        }

        .alert-card small {
            font-weight: 700;
            letter-spacing: 0.02em;
        }

        .alert-card ul {
            margin: 0;
            padding-left: 1.5rem;
        }

        .alert-card li {
            margin-bottom: 0.45rem;
            color: var(--pico-color);
        }

        .alert-card li:last-child {
            margin-bottom: 0;
        }

        .alert-critical {
            border-left: 4px solid var(--pico-del-color);
        }

        .alert-warning {
            border-left: 4px solid #d97706; /* Aviso */
        }

        .alert-info {
            border-left: 4px solid var(--pico-primary);
        }

        .alert-neutral {
            border-left: 4px solid var(--pico-muted-color);
        }

        .chart-card {
            min-height: 340px;
        }

        .chart-wrap {
            position: relative;
            min-height: 260px;
        }

        .empty-state {
            color: #5f6b7a;
            font-style: italic;
            margin: 0;
        }

        .calendar-section {
            margin-bottom: 1.5rem;
        }

        .calendar-shell {
            border: 1px solid var(--pico-muted-border-color);
            border-radius: var(--pico-border-radius);
            background: var(--pico-card-background-color);
            box-shadow: var(--pico-box-shadow);
            padding: 1.2rem;
        }

        .calendar-topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
        }

        .calendar-title h2,
        .calendar-title p {
            margin: 0;
        }

        .calendar-title p {
            color: #5f6b7a;
            font-size: 0.95rem;
        }

        .calendar-actions,
        .calendar-nav {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .calendar-nav a {
            text-decoration: none;
        }

        .calendar-toggle {
            margin: 0;
            white-space: nowrap;
        }

        .calendar-content[hidden] {
            display: none !important;
        }

        .calendar-summary {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 0.8rem;
            margin-bottom: 1rem;
        }

        .calendar-summary article {
            margin: 0;
            padding: 0.9rem 1rem;
            border-radius: 14px;
            border: 1px solid #dfe7ef;
            background: rgba(255, 255, 255, 0.92);
        }

        .calendar-summary strong,
        .calendar-summary span,
        .calendar-summary small {
            display: block;
        }

        .calendar-summary strong {
            color: var(--pico-color);
            font-size: 1.5rem;
        }

        .calendar-summary small,
        .calendar-summary span {
            color: var(--pico-muted-color);
        }

        .calendar-legend {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
            color: #415266;
            font-size: 0.92rem;
        }

        .legend-item {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
        }

        .legend-dot {
            width: 12px;
            height: 12px;
            border-radius: 999px;
            border: 1px solid rgba(15, 23, 42, 0.08);
        }

        .legend-green { background: #dcfce7; }
        .legend-yellow { background: #fef3c7; }
        .legend-red { background: #fee2e2; }

        .calendar-weekdays,
        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 0.55rem;
        }

        .calendar-weekdays {
            margin-bottom: 0.55rem;
        }

        .calendar-weekdays span {
            text-align: center;
            font-weight: 700;
            color: var(--pico-muted-color);
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .calendar-cell {
            min-height: 126px;
        }

        .calendar-empty {
            border-radius: 14px;
            background: rgba(226, 232, 240, 0.28);
        }

        .calendar-day {
            display: block;
            height: 100%;
            padding: 0.75rem;
            border-radius: 14px;
            text-decoration: none;
            border: 1px solid transparent;
            color: var(--pico-color);
            box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.04);
            transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
        }

        .calendar-day:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
            border-color: rgba(18, 59, 109, 0.18);
        }

        .calendar-day.green {
            background: linear-gradient(180deg, #ecfdf3 0%, #dcfce7 100%);
        }

        .calendar-day.yellow {
            background: linear-gradient(180deg, #fff8db 0%, #fef3c7 100%);
        }

        .calendar-day.red {
            background: linear-gradient(180deg, #fff1f2 0%, #fee2e2 100%);
        }

        .calendar-day.today {
            border-color: #123b6d;
            box-shadow: inset 0 0 0 1px rgba(18, 59, 109, 0.12);
        }

        .calendar-day header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.55rem;
        }

        .calendar-day header strong {
            font-size: 1.05rem;
        }

        .calendar-pill {
            border-radius: 999px;
            padding: 0.15rem 0.5rem;
            font-size: 0.72rem;
            font-weight: 700;
            color: #123b6d;
            background: rgba(255, 255, 255, 0.74);
        }

        .calendar-day p,
        .calendar-day small {
            margin: 0;
        }

        .calendar-day p {
            font-weight: 700;
        }

        .calendar-day small {
            display: block;
            margin-top: 0.2rem;
            color: var(--pico-muted-color);
        }

        @media (max-width: 768px) {
            .stats-grid,
            .alerts-grid,
            .panel-grid,
            .calendar-summary {
                grid-template-columns: minmax(0, 1fr);
            }

            .chart-card {
                min-height: 300px;
            }

            .chart-wrap {
                min-height: 220px;
            }

            .calendar-weekdays,
            .calendar-grid {
                gap: 0.4rem;
            }

            .calendar-cell {
                min-height: 96px;
            }

            .calendar-day {
                padding: 0.55rem;
            }

            .calendar-day p {
                font-size: 0.82rem;
            }
        }
    </style>
</head>
<body>
    <main class="container-fluid">
        <%- include('partials/app-header', { title: 'Dashboard de Reservas', user }) %>
        <%- include('partials/admin-nav', { user, activePage: 'dashboard' }) %>

        <h2 style="margin-top: 1rem; margin-bottom: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--pico-muted-border-color);">Dashboard de Reservas</h2>

        <div class="section-stack">
            <section class="period-banner">
                <div>
                    <h2><%= calendarMonth.label %></h2>
                    <p>Todos os indicadores abaixo refletem o mesmo mes, o que deixa a leitura do dashboard mais consistente.</p>
                </div>
                <nav>
                    <a href="/admin/dashboard?month=<%= calendarMonth.previousMonthParam %>" role="button" class="secondary outline">Mes anterior</a>
                    <span class="period-chip"><%= calendarMonth.label %></span>
                    <a href="/admin/dashboard?month=<%= calendarMonth.nextMonthParam %>" role="button" class="secondary outline">Proximo mes</a>
                </nav>
            </section>

            <section class="stats-grid">
                <article class="stat-card">
                    <small>Total de reservas no mes</small>
                    <strong><%= resumo.totalReservas %></strong>
                </article>
                <article class="stat-card">
                    <small>Reservas ativas no mes</small>
                    <strong><%= resumo.totalAtivas %></strong>
                </article>
                <article class="stat-card">
                    <small>Reservas concluidas no mes</small>
                    <strong><%= resumo.totalConcluidas %></strong>
                </article>
                <article class="stat-card">
                    <small>Reservas canceladas no mes</small>
                    <strong><%= resumo.totalCanceladas %></strong>
                    <span>Taxa: <%= resumo.taxaCancelamento %>%</span>
                </article>
                <article class="stat-card">
                    <small>Chromebooks reservados no mes</small>
                    <strong><%= resumo.totalChromebooks %></strong>
                    <span>Media de duracao: <%= resumo.mediaHoras %>h</span>
                </article>
            </section>

            <section class="alerts-grid">
                <article class="alert-card alert-critical">
                    <header>
                        <small>Pressao operacional</small>
                        <h3>Dias criticos nos proximos 7 dias</h3>
                    </header>
                    <% if (alertas.criticosProximos.length) { %>
                        <ul>
                            <% alertas.criticosProximos.forEach(item => { %>
                                <li><strong><%= item.dateKey %></strong>: <%= item.ocupacao %>% da capacidade, <%= item.reservadoNoPico %> reservados no pico.</li>
                            <% }) %>
                        </ul>
                    <% } else { %>
                        <p class="empty-state">Nenhum dia critico previsto para a proxima semana.</p>
                    <% } %>
                </article>

                <article class="alert-card alert-warning">
                    <header>
                        <small>Atencao antecipada</small>
                        <h3>Dias em alerta nos proximos 7 dias</h3>
                    </header>
                    <% if (alertas.atencaoProxima.length) { %>
                        <ul>
                            <% alertas.atencaoProxima.forEach(item => { %>
                                <li><strong><%= item.dateKey %></strong>: <%= item.ocupacao %>% de ocupacao com <%= item.bloqueadoNoPico %> bloqueados.</li>
                            <% }) %>
                        </ul>
                    <% } else { %>
                        <p class="empty-state">Sem dias amarelos no horizonte imediato.</p>
                    <% } %>
                </article>

                <article class="alert-card alert-info">
                    <header>
                        <small>Retiradas do dia</small>
                        <h3>Reservas com retirada hoje</h3>
                    </header>
                    <% if (alertas.retiradasHoje.length) { %>
                        <ul>
                            <% alertas.retiradasHoje.forEach(item => { %>
                                <li><strong><%= item.nome_professor %></strong>: <%= item.quantidade %> no <%= item.nome_carrinho %> as <%= new Date(item.data_retirada).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }) %>.</li>
                            <% }) %>
                        </ul>
                    <% } else { %>
                        <p class="empty-state">Nenhuma retirada ativa com inicio hoje.</p>
                    <% } %>
                </article>

                <article class="alert-card alert-neutral">
                    <header>
                        <small>Manutencao planejada</small>
                        <h3>Bloqueios programados proximos</h3>
                    </header>
                    <% if (alertas.bloqueiosProximos.length) { %>
                        <ul>
                            <% alertas.bloqueiosProximos.forEach(item => { %>
                                <li><strong><%= item.nome_carrinho %></strong>: <%= item.quantidade %> entre <%= item.data_inicio.replace('T', ' ').slice(0, 16) %> e <%= item.data_fim.replace('T', ' ').slice(0, 16) %>.</li>
                            <% }) %>
                        </ul>
                    <% } else { %>
                        <p class="empty-state">Nenhum bloqueio previsto para os proximos dias.</p>
                    <% } %>
                </article>
            </section>

            <section class="panel-grid">
                <article class="chart-card">
                    <header><strong>Reservas por status no mes</strong></header>
                    <% if (statsStatus.length) { %>
                        <div class="chart-wrap">
                            <canvas id="chartStatus"></canvas>
                        </div>
                    <% } else { %>
                        <p class="empty-state">Nenhuma reserva encontrada para montar este grafico.</p>
                    <% } %>
                </article>

                <article class="chart-card">
                    <header><strong>Top 5 carrinhos do mes</strong></header>
                    <% if (statsCarrinhos.length) { %>
                        <div class="chart-wrap">
                            <canvas id="chartCarrinhos"></canvas>
                        </div>
                    <% } else { %>
                        <p class="empty-state">Ainda nao ha uso suficiente para este ranking.</p>
                    <% } %>
                </article>

                <article class="chart-card">
                    <header><strong>Top 5 professores do mes</strong></header>
                    <% if (statsProfessores.length) { %>
                        <div class="chart-wrap">
                            <canvas id="chartProfessores"></canvas>
                        </div>
                    <% } else { %>
                        <p class="empty-state">Nenhum professor apareceu nas reservas do periodo.</p>
                    <% } %>
                </article>

                <article class="chart-card">
                    <header><strong>Reservas ao longo de <%= calendarMonth.label %></strong></header>
                    <% if (statsDias.length) { %>
                        <div class="chart-wrap">
                            <canvas id="chartDias"></canvas>
                        </div>
                    <% } else { %>
                        <p class="empty-state">Nao houve reservas registradas neste mes.</p>
                    <% } %>
                </article>

                <article class="chart-card">
                    <header><strong>Horarios mais usados no mes</strong></header>
                    <% if (statsHorarios.length) { %>
                        <div class="chart-wrap">
                            <canvas id="chartHorarios"></canvas>
                        </div>
                    <% } else { %>
                        <p class="empty-state">Ainda nao existem dados suficientes para este grafico.</p>
                    <% } %>
                </article>

                <article class="chart-card">
                    <header><strong>Top 5 salas do mes</strong></header>
                    <% if (statsSalas.length) { %>
                        <div class="chart-wrap">
                            <canvas id="chartSalas"></canvas>
                        </div>
                    <% } else { %>
                        <p class="empty-state">Nenhuma sala apareceu nas reservas do periodo.</p>
                    <% } %>
                </article>
            </section>

            <section class="calendar-section">
                <div class="calendar-shell">
                    <div class="calendar-topbar">
                        <div class="calendar-title">
                            <h2>Calendario de ocupacao</h2>
                            <p>Leitura diaria da pressao sobre os chromebooks. Clique em um dia para abrir as reservas dele.</p>
                        </div>
                        <div class="calendar-actions">
                            <button
                                type="button"
                                id="calendar-toggle"
                                class="secondary outline calendar-toggle"
                                aria-expanded="true"
                                aria-controls="calendar-content"
                            >
                                Ocultar calendario
                            </button>
                            <div class="calendar-nav">
                                <a href="/admin/dashboard?month=<%= calendarMonth.previousMonthParam %>" role="button" class="secondary outline">Mes anterior</a>
                                <a href="/admin/dashboard" role="button" class="secondary outline">Mes atual</a>
                                <a href="/admin/dashboard?month=<%= calendarMonth.nextMonthParam %>" role="button" class="secondary outline">Proximo mes</a>
                            </div>
                        </div>
                    </div>

                    <div id="calendar-content" class="calendar-content">
                        <div class="calendar-summary">
                            <article>
                                <small>Mes exibido</small>
                                <strong><%= calendarMonth.label %></strong>
                                <span>Base operacional: <%= occupancyCalendar.summary.capacidadeBase %> chromebooks</span>
                            </article>
                            <article>
                                <small>Pico do mes</small>
                                <strong>
                                    <%= occupancyCalendar.summary.worstDay ? `${occupancyCalendar.summary.worstDay.ocupacao}%` : '0%' %>
                                </strong>
                                <span>
                                    <%= occupancyCalendar.summary.worstDay ? `${occupancyCalendar.summary.worstDay.reservadoNoPico} reservados em ${occupancyCalendar.summary.worstDay.dateKey}` : 'Sem reservas neste mes' %>
                                </span>
                            </article>
                            <article>
                                <small>Dias com uso</small>
                                <strong><%= occupancyCalendar.summary.occupiedDays %></strong>
                                <span><%= occupancyCalendar.summary.warningDays %> em alerta e <%= occupancyCalendar.summary.criticalDays %> criticos</span>
                            </article>
                            <article>
                                <small>Media diaria</small>
                                <strong><%= occupancyCalendar.summary.mediaOcupacao %>%</strong>
                                <span>Ocupacao media considerando a capacidade efetiva de cada dia</span>
                            </article>
                        </div>

                        <div class="calendar-legend">
                            <span class="legend-item"><span class="legend-dot legend-green"></span>Verde: ate 60% da capacidade efetiva</span>
                            <span class="legend-item"><span class="legend-dot legend-yellow"></span>Amarelo: de 60,1% a 85%</span>
                            <span class="legend-item"><span class="legend-dot legend-red"></span>Vermelho: acima de 85%</span>
                        </div>

                        <div class="calendar-weekdays" aria-hidden="true">
                            <span>Seg</span>
                            <span>Ter</span>
                            <span>Qua</span>
                            <span>Qui</span>
                            <span>Sex</span>
                            <span>Sab</span>
                            <span>Dom</span>
                        </div>

                        <div class="calendar-grid">
                            <% occupancyCalendar.weeks.forEach(week => { %>
                                <% week.forEach(day => { %>
                                    <div class="calendar-cell <%= day ? '' : 'calendar-empty' %>">
                                        <% if (day) { %>
                                            <a href="/admin?data=<%= day.dateKey %>" class="calendar-day <%= day.nivel %> <%= day.isToday ? 'today' : '' %>">
                                                <header>
                                                    <strong><%= day.dayNumber %></strong>
                                                    <% if (day.isToday) { %>
                                                        <span class="calendar-pill">Hoje</span>
                                                    <% } %>
                                                </header>
                                                <p><%= day.reservadoNoPico %> chromes</p>
                                                <small>Pico do dia</small>
                                                <small><%= day.ocupacao %>% da capacidade efetiva</small>
                                                <small><%= day.bloqueadoNoPico %> bloqueados no pico</small>
                                            </a>
                                        <% } %>
                                    </div>
                                <% }) %>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>
    <%- include('partials/footer') %>

    <script src="/menu.js"></script>
    <script>
        const statsStatus = <%- safeJson(statsStatus) %>;
        const statsCarrinhos = <%- safeJson(statsCarrinhos) %>;
        const statsProfessores = <%- safeJson(statsProfessores) %>;
        const statsDias = <%- safeJson(statsDias) %>;
        const statsHorarios = <%- safeJson(statsHorarios) %>;
        const statsSalas = <%- safeJson(statsSalas) %>;

        const palette = {
            blue: '#1d4ed8',
            blueLight: '#93c5fd',
            green: '#15803d',
            amber: '#d97706',
            red: '#dc2626',
            slate: '#475569',
            cyan: '#0891b2'
        };

        const statusLabels = {
            Ativa: 'Ativa',
            Concluida: 'Concluida',
            Cancelada: 'Cancelada'
        };

        function buildChart(elementId, config) {
            const element = document.getElementById(elementId);
            if (!element) return;
            new Chart(element, config);
        }

        if (statsStatus.length) {
            buildChart('chartStatus', {
                type: 'doughnut',
                data: {
                    labels: statsStatus.map(item => statusLabels[item.status] || item.status),
                    datasets: [{
                        data: statsStatus.map(item => item.qtd),
                        backgroundColor: [palette.blue, palette.red, palette.green, palette.amber, palette.slate]
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });
        }

        if (statsCarrinhos.length) {
            buildChart('chartCarrinhos', {
                type: 'bar',
                data: {
                    labels: statsCarrinhos.map(item => item.nome),
                    datasets: [{
                        label: 'Reservas',
                        data: statsCarrinhos.map(item => item.total),
                        backgroundColor: palette.blue
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true, ticks: { precision: 0 } }
                    },
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        }

        if (statsProfessores.length) {
            buildChart('chartProfessores', {
                type: 'bar',
                data: {
                    labels: statsProfessores.map(item => item.nome),
                    datasets: [{
                        label: 'Reservas',
                        data: statsProfessores.map(item => item.total),
                        backgroundColor: palette.green
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: { beginAtZero: true, ticks: { precision: 0 } }
                    },
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        }

        if (statsDias.length) {
            buildChart('chartDias', {
                type: 'line',
                data: {
                    labels: statsDias.map(item => {
                        const [ano, mes, dia] = item.data.split('-');
                        return `${dia}/${mes}`;
                    }),
                    datasets: [{
                        label: 'Reservas',
                        data: statsDias.map(item => item.qtd),
                        borderColor: palette.amber,
                        backgroundColor: 'rgba(217, 119, 6, 0.15)',
                        fill: true,
                        tension: 0.3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true, ticks: { precision: 0 } }
                    }
                }
            });
        }

        if (statsHorarios.length) {
            buildChart('chartHorarios', {
                type: 'bar',
                data: {
                    labels: statsHorarios.map(item => item.hora),
                    datasets: [{
                        label: 'Reservas',
                        data: statsHorarios.map(item => item.total),
                        backgroundColor: palette.cyan
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true, ticks: { precision: 0 } }
                    },
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        }

        if (statsSalas.length) {
            buildChart('chartSalas', {
                type: 'bar',
                data: {
                    labels: statsSalas.map(item => item.sala),
                    datasets: [{
                        label: 'Reservas',
                        data: statsSalas.map(item => item.total),
                        backgroundColor: palette.slate
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: { beginAtZero: true, ticks: { precision: 0 } }
                    },
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        }

        const calendarToggle = document.getElementById('calendar-toggle');
        const calendarContent = document.getElementById('calendar-content');
        const calendarStorageKey = 'admin-dashboard-calendar-collapsed';

        function setCalendarCollapsed(collapsed) {
            if (!calendarToggle || !calendarContent) return;

            calendarContent.hidden = collapsed;
            calendarToggle.setAttribute('aria-expanded', String(!collapsed));
            calendarToggle.textContent = collapsed ? 'Mostrar calendario' : 'Ocultar calendario';

            try {
                localStorage.setItem(calendarStorageKey, collapsed ? 'true' : 'false');
            } catch (error) {
                // Ignora falhas de armazenamento local sem impactar o dashboard.
            }
        }

        if (calendarToggle && calendarContent) {
            let shouldCollapse = false;

            try {
                shouldCollapse = localStorage.getItem(calendarStorageKey) === 'true';
            } catch (error) {
                shouldCollapse = false;
            }

            setCalendarCollapsed(shouldCollapse);

            calendarToggle.addEventListener('click', () => {
                setCalendarCollapsed(!calendarContent.hidden);
            });
        }
    </script>
</body>
</html>
