<!DOCTYPE html>
<html lang="pt-br" data-theme="white">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestao - Sistema de Reservas</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"/>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <main class="container-fluid">
        <%- include('partials/app-header', { title: 'Painel de Gestao', user }) %>
        <%- include('partials/admin-nav', { user, activePage: 'admin' }) %>

        <div style="display: flex; justify-content: flex-end;">
            <article style="max-width: 650px; padding: 1rem; margin-bottom: 1.5rem;">
                <form action="/admin" method="GET" style="margin-bottom: 0;">
                    <div class="grid" style="align-items: flex-end; grid-template-columns: 2fr 1fr 1fr; gap: 1rem;">
                        <div style="margin-bottom: 0;">
                            <label for="data" style="font-size: 0.85rem; margin-bottom: 0.25rem;">Filtrar por dia:</label>
                            <input type="date" id="data" name="data" value="<%= dataFiltro %>" style="margin-bottom: 0; height: 45px;">
                        </div>
                        <div>
                            <button type="submit" style="margin-bottom: 0; height: 45px; padding: 0;">Filtrar</button>
                        </div>
                        <div>
                            <a href="/admin" role="button" class="secondary outline" style="margin-bottom: 0; height: 45px; padding: 0; display: flex; align-items: center; justify-content: center;">Limpar</a>
                        </div>
                    </div>
                </form>
                <% if (dataFiltro) { %>
                    <p style="margin-top: 10px; margin-bottom: 0; font-size: 0.8rem; color: #1b5e20;">
                        Mostrando: <strong><%= dataFiltro %></strong>
                    </p>
                <% } %>
            </article>
        </div>

        <h2 style="font-weight: bold;">Reservas Ativas no Sistema</h2>

        <div style="overflow-x: auto;">
            <table>
              <thead>
                <tr>
                  <th>Professor</th>
                  <th>Qtde</th>
                  <th>Carrinho</th>
                  <th>Retirada</th>
                  <th>Devolucao</th>
                  <th>Sala</th>
                  <th>Acoes</th>
                </tr>
              </thead>
              <tbody>
                <% function formatarData(dataIso){
                  const data = new Date(dataIso);
                  const dia = String(data.getDate()).padStart(2, '0');
                  const mes = String(data.getMonth()+1).padStart(2, '0');
                  const ano = data.getFullYear();
                  const hora = String(data.getHours()).padStart(2, '0');
                  const minuto = String(data.getMinutes()).padStart(2, '0');
                  return `${hora}:${minuto} ${dia}/${mes}/${ano}`;
                } %>
              
                <% if (reservas.length > 0) { %>
                    <% reservas.forEach(reserva => { %>
                      <tr class="teste2">
                        <td><%= reserva.nome_professor %></td>
                        <td><%= reserva.quantidade %></td>
                        <td><%= reserva.nome_carrinho %></td>
                        <td><%= formatarData(reserva.data_retirada)%></td>
                        <td><%= formatarData(reserva.data_devolucao)%></td>
                        <td><%= reserva.sala %></td>
                        <td>
                          <form action="/reservas/concluir/<%= reserva.id %>" method="POST" style="margin: 0;" onsubmit="return confirm('Realmente deseja concluir esta reserva?');">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="primary">Concluir</button>
                          </form>
                        </td>
                      </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="7" style="text-align: center;">Nenhuma reserva ativa no momento.</td>
                    </tr>
                <% } %>
              </tbody>
            </table>
        </div>
    </main>
    <%- include('partials/footer') %>
</body>
</html>
