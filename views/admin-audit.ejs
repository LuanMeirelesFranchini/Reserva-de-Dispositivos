<!DOCTYPE html>
<html lang="pt-br" data-theme="white">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auditoria do Sistema</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"/>
    <link rel="stylesheet" href="/style.css">
    <style>
        .audit-details {
            max-width: 520px;
            white-space: pre-wrap;
            word-break: break-word;
            font-size: 0.82rem;
            margin: 0;
        }

        .audit-meta {
            white-space: nowrap;
        }
    </style>
</head>
<body>
    <main class="container-fluid">
        <%- include('partials/app-header', { title: 'Auditoria do Sistema', user }) %>
        <%- include('partials/admin-nav', { user, activePage: 'audit' }) %>

        <form action="/admin/audit" method="GET" style="max-width: 600px;">
            <label for="acao">Filtrar por acao</label>
            <div class="grid" style="align-items: center;">
                <select id="acao" name="acao" style="margin-bottom: 0;">
                    <option value="">Todas as acoes</option>
                    <% acoes.forEach(acao => { %>
                        <option value="<%= acao %>" <%= acaoFiltro === acao ? 'selected' : '' %>><%= acao %></option>
                    <% }) %>
                </select>

                <button type="submit" style="margin-bottom: 0;">Filtrar</button>
                <a href="/admin/audit" role="button" class="secondary outline" style="margin-bottom: 0; display: block; text-align: center;">Limpar</a>
            </div>
        </form>
        <div class="table-container">
            <table class="striped">
                <thead>
                    <tr>
                        <th>Quando</th>
                        <th>Usuario</th>
                        <th>Acao</th>
                        <th>Entidade</th>
                        <th>Detalhes</th>
                        <th>IP</th>
                    </tr>
                </thead>
                <tbody>
                    <%
                    function formatarDetalhes(valor) {
                        if (!valor) return '---';
                        try {
                            return JSON.stringify(JSON.parse(valor), null, 2);
                        } catch (err) {
                            return valor;
                        }
                    }
                    %>
                    <% if (logs.length > 0) { %>
                        <% logs.forEach(log => { %>
                            <tr>
                                <td class="audit-meta"><%= log.criado_em %></td>
                                <td>
                                    <strong><%= log.usuario_nome || 'Sistema' %></strong><br>
                                    <small><%= log.usuario_role || '---' %></small>
                                </td>
                                <td><mark><%= log.acao %></mark></td>
                                <td>
                                    <%= log.entidade || '---' %>
                                    <% if (log.entidade_id) { %>
                                        <br><small>ID: <%= log.entidade_id %></small>
                                    <% } %>
                                </td>
                                <td><pre class="audit-details"><%= formatarDetalhes(log.detalhes_json) %></pre></td>
                                <td class="audit-meta"><%= log.ip || '---' %></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="6" style="text-align: center; padding: 2rem;">Nenhum registro de auditoria encontrado.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>
    <%- include('partials/footer') %>
</body>
</html>
