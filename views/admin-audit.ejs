<!DOCTYPE html>
<html lang="pt-br" data-theme="white">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auditoria do Sistema</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"/>
    <link rel="stylesheet" href="/style.css">
    <style>
        .audit-details {
            max-width: 520px;
            white-space: pre-wrap;
            word-break: break-word;
            font-size: 0.82rem;
            margin: 0;
        }

        .audit-meta {
            white-space: nowrap;
        }
    </style>
</head>
<body>
    <main class="container-fluid">
        <%- include('partials/app-header', { title: 'Auditoria do Sistema', user }) %>
        <%- include('partials/admin-nav', { user, activePage: 'audit' }) %>

        <h2 style="margin-top: 1rem; margin-bottom: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--pico-muted-border-color);">Auditoria do Sistema</h2>

        <div style="background: var(--pico-card-background-color); padding: 1rem 1.5rem; border-radius: var(--pico-border-radius); border: 1px solid var(--pico-muted-border-color); margin: 0 auto 1.5rem auto; box-shadow: var(--pico-box-shadow); max-width: fit-content;">
            <form action="/admin/audit" method="GET" style="margin-bottom: 0;">
                <div style="display: flex; align-items: flex-end; gap: 1rem; flex-wrap: wrap; justify-content: center; margin-bottom: 0;">
                    <div style="margin-bottom: 0;">
                        <label for="acao" style="font-size: 0.85rem; margin-bottom: 0.25rem;">Filtrar por acao</label>
                        <select id="acao" name="acao" style="margin-bottom: 0; min-width: 200px;" onchange="this.form.submit()">
                            <option value="">Todas as acoes</option>
                            <% acoes.forEach(acao => { %>
                                <option value="<%= acao %>" <%= acaoFiltro === acao ? 'selected' : '' %>><%= acao %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div style="margin-bottom: 0;">
                        <button type="submit" style="margin-bottom: 0;">Buscar</button>
                    </div>
                    <% if (typeof acaoFiltro !== 'undefined' && acaoFiltro) { %>
                        <div style="margin-bottom: 0;">
                            <a href="/admin/audit" role="button" class="secondary outline" style="margin-bottom: 0; display: block; text-align: center;">Limpar</a>
                        </div>
                    <% } %>
                </div>
            </form>
        </div>
        <div class="table-container" style="overflow-x: auto; margin-bottom: 2rem;">
            <table class="striped">
                <thead>
                    <tr>
                        <th>Quando</th>
                        <th>Usuario</th>
                        <th>Acao</th>
                        <th>Entidade</th>
                        <th>Detalhes</th>
                        <th>IP</th>
                    </tr>
                </thead>
                <tbody>
                    <%
                    function formatarDetalhes(valor) {
                        if (!valor) return '---';
                        try {
                            return JSON.stringify(JSON.parse(valor), null, 2);
                        } catch (err) {
                            return valor;
                        }
                    }
                    %>
                    <% if (logs.length > 0) { %>
                        <% logs.forEach(log => { %>
                            <tr>
                                <td class="audit-meta"><%= log.criado_em %></td>
                                <td>
                                    <strong><%= log.usuario_nome || 'Sistema' %></strong><br>
                                    <small><%= log.usuario_role || '---' %></small>
                                </td>
                                <td><mark><%= log.acao %></mark></td>
                                <td>
                                    <%= log.entidade || '---' %>
                                    <% if (log.entidade_id) { %>
                                        <br><small>ID: <%= log.entidade_id %></small>
                                    <% } %>
                                </td>
                                <td><pre class="audit-details"><%= formatarDetalhes(log.detalhes_json) %></pre></td>
                                <td class="audit-meta"><%= log.ip || '---' %></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="6" style="text-align: center; padding: 2rem;">Nenhum registro de auditoria encontrado.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>
    <%- include('partials/footer') %>
</body>
</html>
