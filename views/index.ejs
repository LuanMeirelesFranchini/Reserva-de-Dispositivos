<!DOCTYPE html>
<html lang="pt-br" data-user-role="<%= user.role %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reserva de Dispositivos - La Salle</title>
    <script src="/theme.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"/>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/material_blue.css">
</head>
<body>
    <main class="container-fluid">
        <%- include('partials/app-header', { title: 'Sistema de Reservas', user, showNewReservation: false }) %>

        <h2>Disponibilidade por Carrinho</h2>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Carrinho</th>
                        <th>Localizacao</th>
                        <th style="text-align: center;">Capacidade Total</th>
                    </tr>
                </thead>
                <tbody>
                    <% carrinhos.forEach(c => { %>
                    <tr>
                        <td><%= c.nome %></td>
                        <td><%= c.localizacao %></td>
                        <td style="text-align: center;"><strong><%= c.capacidade %></strong></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <hr>

        <details open>
            <summary role="button" class="outline">Fazer uma Nova Reserva</summary>
            <form id="formReserva" action="/reservar" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <label for="carrinho">De qual carrinho quer reservar?</label>
                <select id="carrinho" name="carrinho_id" required>
                    <option value="" disabled selected>Escolha um carrinho</option>
                    <% carrinhos.forEach(c => { %>
                        <option value="<%= c.id %>" data-max="<%= c.disponiveis %>">
                            <%= c.nome %> - <%= c.localizacao %>
                        </option>
                    <% }) %>
                </select>

                <label for="quantidade">Quantidade:</label>
                <input type="number" id="quantidade" name="quantidade" required min="1" placeholder="Selecione um carrinho primeiro">

                <div class="grid">
                    <label for="retirada">Data e Hora de Retirada:
                        <input type="text" id="retirada" name="data_retirada" required placeholder="Selecione data e hora...">
                    </label>
                    <label for="devolucao">Data e Hora de Devolucao:
                        <input type="text" id="devolucao" name="data_devolucao" required placeholder="Selecione data e hora...">
                    </label>
                </div>

                <div class="grid">
                    <label for="bloco">Bloco:
                        <select id="bloco" name="bloco" required>
                            <option value="" disabled selected>Selecione um bloco</option>
                            <% blocosSalas.forEach(bloco => { %>
                                <option value="<%= bloco.valor %>"><%= bloco.label %></option>
                            <% }) %>
                        </select>
                    </label>
                    <label for="sala">Sala / local:
                        <select id="sala" name="sala" required disabled>
                            <option value="" disabled selected>Selecione primeiro um bloco</option>
                        </select>
                    </label>
                </div>
                
                <p><b>Disponibilidade para este horario: <span id="disponibilidade-resultado">--</span></b></p>
        
                <button type="submit" id="btnReservar">Reservar</button>
            </form>
        </details>
    </main>
    <%- include('partials/footer') %>
    
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://npmcdn.com/flatpickr/dist/l10n/pt.js"></script>
    <script src="/menu.js"></script>
    <script src="/front-end.js"></script>
    <script id="salas-por-bloco-data" type="application/json"><%- safeJson(blocosSalas) %></script>
    
    <script>
        const selectCarrinho = document.getElementById('carrinho');
        const inputQuantidade = document.getElementById('quantidade');
        const selectBloco = document.getElementById('bloco');
        const selectSala = document.getElementById('sala');
        const blocosSalas = JSON.parse(document.getElementById('salas-por-bloco-data').textContent);
        const salasPorBloco = blocosSalas.reduce((acc, bloco) => {
            acc[bloco.valor] = bloco.salas;
            return acc;
        }, {});

        selectCarrinho.addEventListener('change', function() {
            const option = this.options[this.selectedIndex];
            const maxDisponivel = option.getAttribute('data-max');
            
            inputQuantidade.max = maxDisponivel;
            inputQuantidade.placeholder = `Maximo: ${maxDisponivel} unidades`;
            
            if (parseInt(inputQuantidade.value) > parseInt(maxDisponivel)) {
                inputQuantidade.value = maxDisponivel;
            }
        });

        inputQuantidade.addEventListener("input", function(){
            const max = parseInt(this.max);
            if (max && parseInt(this.value) > max) {
                this.value = max;
            }
        });

        function preencherSalasDoBloco(blocoSelecionado) {
            selectSala.innerHTML = '';

            if (!blocoSelecionado || !salasPorBloco[blocoSelecionado]) {
                selectSala.disabled = true;
                selectSala.innerHTML = '<option value="" disabled selected>Selecione primeiro um bloco</option>';
                return;
            }

            selectSala.disabled = false;
            selectSala.innerHTML = '<option value="" disabled selected>Selecione uma sala</option>';

            salasPorBloco[blocoSelecionado].forEach((sala) => {
                const option = document.createElement('option');
                option.value = sala.valor;
                option.textContent = sala.label;
                selectSala.appendChild(option);
            });
        }

        selectBloco.addEventListener('change', function() {
            preencherSalasDoBloco(this.value);
        });

        const form = document.getElementById('formReserva');
        const btn = document.getElementById('btnReservar');

        if (form && btn) {
            form.addEventListener('submit', function() {
                btn.setAttribute('aria-busy', 'true');
                btn.disabled = true;
                btn.textContent = 'Processando sua reserva...';
            });
        }
    </script>
</body>
</html>
