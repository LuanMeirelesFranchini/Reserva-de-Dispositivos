<!DOCTYPE html>
<html lang="pt-br" data-theme="white">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Gerir Utilizadores</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"/>
    <link rel="stylesheet" href="/style.css">
    <style>
        .action-stack { display: flex; gap: 10px; align-items: center; justify-content: flex-start; flex-wrap: nowrap; min-width: 600px; }
        .role-form { display: flex; gap: 0.5rem; align-items: center; margin: 0; flex: 1; }
        .action-stack form { margin: 0; }
        .role-form select, .role-form button, .delete-button { margin: 0; height: 44px; }
        .role-form select { height: 45px; min-width: 180px; padding-top: 0; padding-bottom: 0; }
        .role-form button, .delete-button { min-width: 160px; display: inline-flex; align-items: center; justify-content: center; text-align: center; white-space: nowrap; }
        .self-role-note { display: inline-flex; align-items: center; justify-content: flex-start; min-height: 44px; white-space: nowrap; }
        .muted-note { color: #666; font-size: 0.92rem; margin: 0 0 1rem; }
        .users-table th.col-acoes, .users-table td.col-acoes { min-width: 640px; }
    </style>
</head>
<body>
    <main class="container-fluid">
        <%- include('partials/app-header', { title: 'Painel do Administrador', user }) %>
        <%- include('partials/admin-nav', { user, activePage: 'users' }) %>

        <h2 style="margin-top: 1rem; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--pico-muted-border-color);">Usuarios que efetuaram login no sistema</h2>
        <p class="muted-note" style="margin-bottom: 1.5rem;">Use o filtro para localizar rapidamente um usuario e altere o perfil pelo seletor.</p>

        <div style="background: var(--pico-card-background-color); padding: 1rem 1.5rem; border-radius: var(--pico-border-radius); border: 1px solid var(--pico-muted-border-color); margin: 0 auto 1.5rem auto; box-shadow: var(--pico-box-shadow); max-width: fit-content;">
            <div style="display: flex; align-items: flex-end; gap: 1rem; flex-wrap: wrap; justify-content: center; margin-bottom: 0;">
                <div style="margin-bottom: 0;">
                    <label for="filtro-usuarios" style="font-size: 0.85rem; margin-bottom: 0.25rem;">Procurar usuario</label>
                    <input type="search" id="filtro-usuarios" placeholder="Digite nome, e-mail ou perfil" style="margin-bottom: 0; min-width: 350px;">
                </div>
            </div>
        </div>
        
        <div class="table-container" style="overflow-x: auto; margin-bottom: 2rem;">
            <table class="users-table striped">
              <thead>
                <tr>
                  <th class="col-nome">Nome</th>
                  <th class="col-email">E-mail</th>
                  <th class="col-papel">Funcao</th>
                  <th class="col-acoes">Alterar Permissao</th>
                </tr>
              </thead>
              <tbody>
                <% usuarios.forEach(usuario => { %>
                  <tr data-user-row data-search="<%= `${usuario.nome} ${usuario.email} ${usuario.role}`.toLowerCase() %>">
                    <td><%= usuario.nome %></td>
                    <td><%= usuario.email %></td>
                    <td><%= usuario.role.charAt(0).toUpperCase() + usuario.role.slice(1) %></td>
                    <td class="col-acoes">
                      <div class="action-stack">
                        <% if (usuario.id !== user.id) { %>
                          <form action="/admin/set-role/<%= usuario.id %>" method="POST" class="role-form">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <select name="role" aria-label="Selecionar perfil para <%= usuario.nome %>">
                              <option value="professor" <%= usuario.role === 'professor' ? 'selected' : '' %>>Professor</option>
                              <option value="operacional" <%= usuario.role === 'operacional' ? 'selected' : '' %>>Operacional</option>
                              <option value="admin" <%= usuario.role === 'admin' ? 'selected' : '' %>>Admin</option>
                            </select>
                            <button type="submit" class="outline">Salvar perfil</button>
                          </form>

                          <form action="/admin/delete/<%= usuario.id %>" method="POST" onsubmit="return confirm('Tem a certeza de que deseja excluir este utilizador?');">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                              <button type="submit" class="contrast delete-button">Excluir</button>
                          </form>
                        <% } else { %>
                          <p class="self-role-note">(Administrador)</p>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
        </div>
    </main>
    <%- include('partials/footer') %>
    <script>
        const filtroUsuarios = document.getElementById('filtro-usuarios');
        const linhasUsuarios = Array.from(document.querySelectorAll('[data-user-row]'));

        filtroUsuarios.addEventListener('input', function() {
            const termo = this.value.trim().toLowerCase();

            linhasUsuarios.forEach((linha) => {
                const textoBusca = linha.getAttribute('data-search') || '';
                linha.style.display = !termo || textoBusca.includes(termo) ? '' : 'none';
            });
        });
    </script>
</body>
</html>
