PORT=3000
NODE_ENV="development"

DB_HOST="Coloque aqui o host do banco (ex: localhost)"
DB_PORT="Coloque aqui a porta do banco (ex: 3306)"
DB_USER="Coloque aqui o usuário do banco"
DB_PASSWORD="Coloque aqui a senha do banco"
DB_NAME="Coloque aqui o nome do banco de dados"
DB_CONNECTION_LIMIT=10

SESSION_SECRET="Coloque aqui sua sessão secreta"
TOKEN_ENCRYPTION_KEY="Opcional: chave longa para criptografar tokens Google em repouso"

GOOGLE_CLIENT_ID="Coloque aqui seu Client ID do Google"
GOOGLE_CLIENT_SECRET="Coloque aqui seu Client Secret do Google"
GOOGLE_CALENDAR_ENABLED=false

SMTP_HOST="Coloque aqui seu host de SMTP"
SMTP_PORT="Coloque aqui sua porta de SMTP"
SMTP_SECURE=false
EMAIL_USER="Coloque aqui seu email de envio"
EMAIL_PASS="Coloque aqui sua senha de app"
EMAIL_FROM="Coloque aqui o titulo (identificador do seu e-mail)"

INITIAL_ADMIN_EMAIL="Coloque aqui seu e-mail inicial - Será usado como administrador do site"
INITIAL_ADMIN_PASSWORD="Coloque aqui uma senha inicial forte com pelo menos 12 caracteres"
MANAGER_EMAIL="Coloque aqui seu e-mail de gerente (Administrador)"
