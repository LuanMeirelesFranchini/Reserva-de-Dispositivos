{
  "source": {
    "include": [
      "helpers",
      "services",
      "middlewares",
      "database.js",
      "README.md"
    ],
    "includePattern": ".js$",
    "excludePattern": "(node_modules/|docs/|public/|scripts/)"
  },
  "opts": {
    "destination": "./docs/",
    "encoding": "utf8",
    "readme": "README.md",
    "recurse": true,
    "template": "node_modules/better-docs",
    "theme_opts": {
      "default_theme": "dark"
    }
  }
}
